{
	"config": "air",
	"compilerOptions": {
		"source-path": [
			"src"
		],
		"library-path": [
			"libs"
		],
		"output": "bin/comptest.swf",
		"default-background-color": "#ffffff",
		"default-frame-rate": 60,
		"default-size": {
			"width": 800,
			"height": 800
		},
		"swf-version": 18
	},
	"application": "src/comptest-app.xml",
	"mainClass": "comptest"
}