{
	"config": "air",
	"compilerOptions": {
		"source-path": [
			"src"
		],
		"library-path": [
			"libs"
		],
		"output": "bin/skinnotificationsdefault.swf",
		"default-background-color": "#ffffff",
		"default-frame-rate": 24,
		"default-size": {
			"width": 550,
			"height": 550
		},
		"swf-version": 28
	},
	"application": "src/skinnotificationsdefault-app.xml",
	"mainClass": "skin_notifications_default_fla.MainTimeline"
}