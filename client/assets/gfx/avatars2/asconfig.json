{
	"config": "air",
	"compilerOptions": {
		"source-path": [
			"src"
		],
		"library-path": [
			"libs"
		],
		"output": "bin/avatars2.swf",
		"default-background-color": "#cccccc",
		"default-frame-rate": 60,
		"default-size": {
			"width": 550,
			"height": 550
		},
		"swf-version": 21
	},
	"application": "src/avatars2-app.xml",
	"mainClass": "null"
}